      cta: "Agendar una llamada"
    },
    hero: {
      eyebrow: "Estrategia técnica y desarrollo",
      title: "Desarrollamos productos SaaS con bases sólidas en software, datos e IA",
      copy:
        "Ayudamos a definir qué construir, desarrollar el producto, estructurar la capa de datos y convertir la AI en capacidades útiles dentro del negocio y del producto.",
