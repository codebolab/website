          title: "Build",
          description:
            "Construimos de forma iterativa, con feedback frecuente, avances visibles y una secuencia práctica de entregas."
        },
        {
          title: "Scale",
          description:
            "Mejoramos el sistema con mejor analytics, infraestructura, automatización y capacidades de AI a medida que el producto madura."
        }
      ]
    },
    cta: {
      eyebrow: "¿Listo para construir tu producto?",
      title: "¿Listo para construir tu producto?",
