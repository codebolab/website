        <BrandLogo size="sm" />
        <nav class="nav-links" aria-label="Primary">
          <a href="#approach" class="active" data-i18n="nav.approach">{content.nav.approach}</a>
          <a href="#services" data-i18n="nav.services">{content.nav.services}</a>
          <a href="#why" data-i18n="nav.why">{content.nav.why}</a>
          <a href="#process" data-i18n="nav.process">{content.nav.process}</a>
        </nav>
        <a class="button button--primary button--small" href="#cta" data-i18n="nav.cta">{content.nav.cta}</a>
      </div>
    </header>

    <main>
      <section class="hero section">
        <div class="hero__brackets" aria-hidden="true">
          <span>(</span>
          <span>)</span>
        </div>
        <div class="container hero__inner">
          <div class="hero__eyebrow">
            <span class="hero__signal"></span>
            <span data-i18n="hero.eyebrow">{content.hero.eyebrow}</span>
          </div>

          <h1 data-i18n="hero.title" data-i18n-html>{content.hero.title}</h1>

          <p class="hero__copy" data-i18n="hero.copy">{content.hero.copy}</p>

          <div class="hero__actions">
            <a class="button button--primary" href="#cta" data-i18n="hero.primaryCta">{content.hero.primaryCta}</a>
            <a class="button button--ghost" href="#services">
              <span data-i18n="hero.secondaryCta">{content.hero.secondaryCta}</span>
              <span class="material-symbols-outlined" style="font-size: 1.1rem;">arrow_forward</span>
            </a>
          </div>
        </div>
      </section>

      <section class="section section--alt">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow" data-i18n="problem.eyebrow">{content.problem.eyebrow}</p>
            <h2 data-i18n="problem.title" data-i18n-html>{content.problem.title}</h2>
          </div>

          <div class="problem-grid">
            {content.problem.items.map((item, index) => (
              <article class="problem-card">
                <span class={`material-symbols-outlined problem-card__icon problem-card__icon--${["mint", "sky", "tertiary", "mint"][index]}`}>
