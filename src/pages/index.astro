          <div class="section-heading section-heading--center">
            <p class="eyebrow" data-i18n="services.eyebrow">{content.services.eyebrow}</p>
            <h2 data-i18n="services.title">{content.services.title}</h2>
          </div>

          <div class="service-grid">
            {content.services.items.map((service, index) => (
