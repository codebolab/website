          <div class="cta-card">
            <p class="eyebrow" data-i18n="cta.eyebrow">{content.cta.eyebrow}</p>
            <h2 data-i18n="cta.title">{content.cta.title}</h2>
            <p data-i18n="cta.copy">{content.cta.copy}</p>
            <div class="hero__actions">
              <a class="button button--primary" href="mailto:hello@codebolab.com" data-i18n="cta.primary">{content.cta.primary}</a>
              <a class="button button--ghost" href="#process" data-i18n="cta.secondary">{content.cta.secondary}</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <section class="section location-section">
      <div class="container location-grid">
        <div class="location-copy">
          <p class="eyebrow" data-i18n="footer.locationEyebrow">{content.footer.locationEyebrow}</p>
          <h2 data-i18n="footer.locationTitle">{content.footer.locationTitle}</h2>
          <p data-i18n="footer.contactTitle">{content.footer.contactTitle}</p>

          <dl class="contact-list">
            <div class="contact-list__item">
              <dt data-i18n="footer.phoneLabel">{content.footer.phoneLabel}</dt>
              <dd>
                <a href="tel:+59144063924" data-i18n="footer.phoneValue">{content.footer.phoneValue}</a>
              </dd>
            </div>
            <div class="contact-list__item">
              <dt data-i18n="footer.emailLabel">{content.footer.emailLabel}</dt>
              <dd>
                <a href="mailto:info@code.bo" data-i18n="footer.emailValue">{content.footer.emailValue}</a>
              </dd>
            </div>
          </dl>
        </div>

        <div class="location-map">
          <div class="location-map__frame">
            <iframe
              title="Code.bo office location"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q=Av.%20Antezana%20No%20847%20Piso%204%20Of.%203%20entre%20Oruro%20y%20La%20Paz%2C%20Cochabamba%2C%20Bolivia&z=16&output=embed">
            </iframe>
          </div>
          <div class="location-map__address">
            <span data-i18n="footer.addressLabel">{content.footer.addressLabel}</span>
            <p data-i18n="footer.addressValue">{content.footer.addressValue}</p>
          </div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer">
        <div>
          <span class="footer__brand">CodeboLab</span>
          <p data-i18n="footer.copy">{content.footer.copy}</p>
        </div>

        <div class="footer__links">
          <a href="#services" data-i18n="footer.services">{content.footer.services}</a>
          <a href="#why" data-i18n="footer.why">{content.footer.why}</a>
          <a href="#process" data-i18n="footer.process">{content.footer.process}</a>
