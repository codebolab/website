          <div class="approach__content">
            <p class="eyebrow" data-i18n="approach.eyebrow">{content.approach.eyebrow}</p>
            <h2 data-i18n="approach.title">{content.approach.title}</h2>
            <p data-i18n="approach.copy">{content.approach.copy}</p>

            <div class="signal-panel" aria-hidden="true">
              <div class="signal-panel__grid"></div>
              <div class="signal-panel__icon">
                <span class="material-symbols-outlined">hub</span>
              </div>
            </div>
          </div>

          <div class="approach__list">
            {content.approach.items.map((item, index) => (
              <div class="approach-step">
                <span class="approach-step__num">{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3 data-i18n={`approach.items.${index}.title`}>{item.title}</h3>
                  <p data-i18n={`approach.items.${index}.body`}>{item.body}</p>
