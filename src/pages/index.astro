      eyebrow: "Áreas de expertise",
      title: "Lo que construimos.",
      items: [
        {
          title: "Productos SaaS",
          description:
            "Desarrollamos productos SaaS con el discovery, la arquitectura y la base técnica necesarias para lanzar bien y evolucionar sin retrabajo costoso.",
          features: ["Definición de alcance y arquitectura", "Frontend, backend, APIs y base de datos", "Infraestructura inicial y despliegue"]
        },
        {
          title: "Data foundations y analytics",
          description:
            "Estructuramos datos, tracking y reporting para que el equipo pueda medir lo importante y tomar mejores decisiones operativas.",
          features: ["Eventos y métricas clave", "Pipelines y reporting", "Visibilidad operativa"]
        },
        {
          title: "Features y workflows con AI",
          description:
            "Integramos capacidades prácticas de AI en productos y operaciones internas, desde asistentes hasta automatización y enriquecimiento de información.",
          features: ["Asistentes y copilots", "Workflows con LLMs", "Búsqueda, extracción y enriquecimiento"]
        }
      ]
    },
    why: {
      eyebrow: "Ventaja competitiva",
      title: "Por qué CodeboLab.",
      quote:
        "\"Cerramos la brecha entre la estrategia de negocio y la ejecución técnica concreta.\"",
      items: [
        {
          label: "01. Pensamiento product-first",
          body: "Pensamos primero en retorno y valor de negocio antes que en el código. Cada feature debe justificar su peso técnico."
        },
        {
          label: "02. Experiencia en data / AI",
          body: "No solo agregamos AI. Diseñamos pipelines de datos que hacen que la inteligencia artificial sea útil y confiable para tus usuarios."
        },
        {
          label: "03. Equipo de alto rendimiento",
          body: "Squads pequeños y senior. Sin capas innecesarias, sin sobrecarga, solo capacidad real de ejecución."
        },
