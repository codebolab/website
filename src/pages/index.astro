const content = translations.en;

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://codebolab.com/#organization",
    name: "CodeboLab",
    url: "https://codebolab.com/",
    email: "hello@codebolab.com",
    description: pageDescription,
    logo: "https://codebolab.com/favicon.svg"
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://codebolab.com/#website",
    url: "https://codebolab.com/",
    name: "CodeboLab",
    description: pageDescription,
    inLanguage: "en"
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": "https://codebolab.com/#service",
    name: "CodeboLab",
    url: "https://codebolab.com/",
    description: pageDescription,
    serviceType: [
      "Product discovery and technical architecture",
      "SaaS product development",
      "MVP development",
      "Data engineering",
      "Analytics implementation",
      "AI workflows and product integration"
    ],
    areaServed: "Worldwide",
    email: "hello@codebolab.com",
    brand: {
      "@type": "Brand",
      name: "CodeboLab"
    },
    offers: [
      {
        "@type": "Offer",
        name: "SaaS product development"
      },
      {
        "@type": "Offer",
        name: "Data foundations and analytics"
      },
      {
        "@type": "Offer",
        name: "AI features and workflows"
      }
    ]
  }
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path="/"
  ogImage="/og-image.svg"
  structuredData={structuredData}
>
  <div id="top" class="site-shell">
    <header class="site-header">
      <div class="container nav">
        <BrandLogo size="sm" />
        <nav class="nav-links" aria-label="Primary">
          <a href="#approach" class="active" data-i18n="nav.approach" data-track-click="nav_approach" data-track-section="header">{content.nav.approach}</a>
          <a href="#services" data-i18n="nav.services" data-track-click="nav_services" data-track-section="header">{content.nav.services}</a>
          <a href="#why" data-i18n="nav.why" data-track-click="nav_why" data-track-section="header">{content.nav.why}</a>
          <a href="#process" data-i18n="nav.process" data-track-click="nav_process" data-track-section="header">{content.nav.process}</a>
        </nav>
        <a class="button button--primary button--small" href="#cta" data-i18n="nav.cta" data-track-click="nav_primary_cta" data-track-section="header">{content.nav.cta}</a>
      </div>
    </header>

    <main>
      <section class="hero section">
        <div class="hero__brackets" aria-hidden="true">
          <span>(</span>
          <span>)</span>
        </div>
        <div class="container hero__inner">
          <div class="hero__eyebrow">
            <span class="hero__signal"></span>
            <span data-i18n="hero.eyebrow">{content.hero.eyebrow}</span>
          </div>

          <h1 data-i18n="hero.title" data-i18n-html>{content.hero.title}</h1>

          <p class="hero__copy" data-i18n="hero.copy">{content.hero.copy}</p>

          <div class="hero__actions">
            <a class="button button--primary" href="#cta" data-i18n="hero.primaryCta" data-track-click="hero_primary_cta" data-track-section="hero">{content.hero.primaryCta}</a>
            <a class="button button--ghost" href="#services" data-track-click="hero_secondary_cta" data-track-section="hero">
              <span data-i18n="hero.secondaryCta">{content.hero.secondaryCta}</span>
              <span class="material-symbols-outlined" style="font-size: 1.1rem;">arrow_forward</span>
            </a>
          </div>
        </div>
      </section>

      <section class="section section--alt">
        <div class="container">
          <div class="section-heading">
            <p class="eyebrow" data-i18n="problem.eyebrow">{content.problem.eyebrow}</p>
            <h2 data-i18n="problem.title" data-i18n-html>{content.problem.title}</h2>
          </div>

          <div class="problem-grid">
            {content.problem.items.map((item, index) => (
              <article class="problem-card">
                <span class={`material-symbols-outlined problem-card__icon problem-card__icon--${["mint", "sky", "tertiary", "mint"][index]}`}>
                  {["foundation", "speed", "analytics", "psychology"][index]}
                </span>
                <h3 data-i18n={`problem.items.${index}.title`}>{item.title}</h3>
                <p data-i18n={`problem.items.${index}.body`}>{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="approach" class="section">
        <div class="container approach">
          <div class="approach__content">
            <p class="eyebrow" data-i18n="approach.eyebrow">{content.approach.eyebrow}</p>
            <h2 data-i18n="approach.title">{content.approach.title}</h2>
            <p data-i18n="approach.copy">{content.approach.copy}</p>

            <div class="signal-panel" aria-hidden="true">
              <div class="signal-panel__grid"></div>
              <div class="signal-panel__icon">
                <span class="material-symbols-outlined">hub</span>
              </div>
            </div>
          </div>

          <div class="approach__list">
            {content.approach.items.map((item, index) => (
              <div class="approach-step">
                <span class="approach-step__num">{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3 data-i18n={`approach.items.${index}.title`}>{item.title}</h3>
                  <p data-i18n={`approach.items.${index}.body`}>{item.body}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="services" class="section section--panel section--bracketed">
        <div class="container">
          <div class="section-heading section-heading--center">
            <p class="eyebrow" data-i18n="services.eyebrow">{content.services.eyebrow}</p>
            <h2 data-i18n="services.title">{content.services.title}</h2>
          </div>

          <div class="service-grid">
            {content.services.items.map((service, index) => (
              <article class={`service-card service-card--${serviceAccents[index]}`}>
                <div class={`service-card__icon service-card__icon--${serviceAccents[index]}`}>
                  <span class="material-symbols-outlined">{serviceIcons[index]}</span>
                </div>
                <h3 data-i18n={`services.items.${index}.title`}>{service.title}</h3>
                <p data-i18n={`services.items.${index}.description`}>{service.description}</p>
                <ul class="service-card__features">
                  {service.features.map((feat, featureIndex) => (
                    <li>
                      <span class={`service-card__bullet service-card__bullet--${serviceAccents[index]}`}></span>
                      <span data-i18n={`services.items.${index}.features.${featureIndex}`}>{feat}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="why" class="section">
        <div class="container">
          <div class="why-heading-row">
            <div class="section-heading" style="margin-bottom: 0;">
              <p class="eyebrow" data-i18n="why.eyebrow">{content.why.eyebrow}</p>
              <h2 style="margin-top: 0.75rem;" data-i18n="why.title">{content.why.title}</h2>
            </div>
            <p class="why-quote" data-i18n="why.quote">{content.why.quote}</p>
          </div>

          <div class="why-grid">
            {content.why.items.map((item, index) => (
              <article class="why-card">
                <span class="why-card__label" data-i18n={`why.items.${index}.label`}>{item.label}</span>
                <p data-i18n={`why.items.${index}.body`}>{item.body}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="process" class="section section--alt">
        <div class="container">
          <div class="section-heading section-heading--center">
            <p class="eyebrow" data-i18n="process.eyebrow">{content.process.eyebrow}</p>
            <h2 data-i18n="process.title">{content.process.title}</h2>
          </div>

          <div class="process-grid">
            <div class="process-line" aria-hidden="true"></div>
            {content.process.items.map((item, index) => (
              <article class="process-card">
                <div class={`process-card__badge process-card__badge--${["mint", "sky", "tertiary"][index]}`}>
                  <span class="material-symbols-outlined">{["search", "terminal", "auto_graph"][index]}</span>
                </div>
                <h3 data-i18n={`process.items.${index}.title`}>{item.title}</h3>
                <p data-i18n={`process.items.${index}.description`}>{item.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="cta" class="section cta-section">
        <div class="container">
          <div class="cta-card">
            <p class="eyebrow" data-i18n="cta.eyebrow">{content.cta.eyebrow}</p>
            <h2 data-i18n="cta.title">{content.cta.title}</h2>
            <p data-i18n="cta.copy">{content.cta.copy}</p>
            <div class="hero__actions">
              <a class="button button--primary" href="mailto:hello@codebolab.com" data-i18n="cta.primary" data-track-click="cta_primary_email" data-track-section="final_cta">{content.cta.primary}</a>
              <a class="button button--ghost" href="#process" data-i18n="cta.secondary" data-track-click="cta_secondary_process" data-track-section="final_cta">{content.cta.secondary}</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <section class="section location-section">
      <div class="container location-grid">
        <div class="location-copy">
          <p class="eyebrow" data-i18n="footer.locationEyebrow">{content.footer.locationEyebrow}</p>
          <h2 data-i18n="footer.locationTitle">{content.footer.locationTitle}</h2>
          <p data-i18n="footer.contactTitle">{content.footer.contactTitle}</p>

          <dl class="contact-list">
            <div class="contact-list__item">
              <dt data-i18n="footer.phoneLabel">{content.footer.phoneLabel}</dt>
              <dd>
                <a href="tel:+59144063924" data-i18n="footer.phoneValue" data-track-click="footer_phone" data-track-section="footer_contact">{content.footer.phoneValue}</a>
              </dd>
            </div>
            <div class="contact-list__item">
              <dt data-i18n="footer.emailLabel">{content.footer.emailLabel}</dt>
              <dd>
                <a href="mailto:info@code.bo" data-i18n="footer.emailValue" data-track-click="footer_email" data-track-section="footer_contact">{content.footer.emailValue}</a>
              </dd>
            </div>
          </dl>
        </div>

        <div class="location-map">
          <div class="location-map__frame">
            <iframe
              title="Code.bo office location"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q=Av.%20Antezana%20No%20847%20Piso%204%20Of.%203%20entre%20Oruro%20y%20La%20Paz%2C%20Cochabamba%2C%20Bolivia&z=16&output=embed">
            </iframe>
          </div>
          <div class="location-map__address">
            <span data-i18n="footer.addressLabel">{content.footer.addressLabel}</span>
            <p data-i18n="footer.addressValue">{content.footer.addressValue}</p>
          </div>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer">
        <div>
          <span class="footer__brand">CodeboLab</span>
          <p data-i18n="footer.copy">{content.footer.copy}</p>
        </div>

        <div class="footer__links">
          <a href="#services" data-i18n="footer.services" data-track-click="footer_services" data-track-section="footer_nav">{content.footer.services}</a>
          <a href="#why" data-i18n="footer.why" data-track-click="footer_why" data-track-section="footer_nav">{content.footer.why}</a>
          <a href="#process" data-i18n="footer.process" data-track-click="footer_process" data-track-section="footer_nav">{content.footer.process}</a>
          <a href="#" data-i18n="footer.linkedin" data-track-click="footer_linkedin" data-track-section="footer_nav">{content.footer.linkedin}</a>
        </div>

        <span class="footer__copy" data-i18n="footer.copyright">{content.footer.copyright}</span>
      </div>
    </footer>
  </div>

  <script is:inline define:vars={{ translations }}>
    const dictionaries = translations;
    const defaultLocale = "en";
    const browserLocale = (navigator.languages?.[0] || navigator.language || defaultLocale).toLowerCase();
    const locale = browserLocale.startsWith("es") ? "es" : defaultLocale;

    const getByPath = (source, path) =>
      path.split(".").reduce((current, key) => current?.[key], source);

    const translatePage = (selectedLocale) => {
      const dictionary = dictionaries[selectedLocale];
      if (!dictionary || selectedLocale === defaultLocale) {
        document.documentElement.lang = defaultLocale;
        return;
      }

      document.documentElement.lang = selectedLocale;

      document.querySelectorAll("[data-i18n]").forEach((node) => {
        const key = node.getAttribute("data-i18n");
        const value = getByPath(dictionary, key);

        if (typeof value !== "string") return;

        if (node.hasAttribute("data-i18n-html")) {
          node.innerHTML = value;
          return;
        }

        node.textContent = value;
      });
    };

    translatePage(locale);
  </script>
</BaseLayout>
